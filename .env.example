# API ASP.NET Core
# Use estes nomes na hospedagem da API, nao no frontend.
ConnectionStrings__CoopDesk=Server=(localdb)\\mssqllocaldb;Database=CoopDeskDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True
Jwt__Issuer=CoopDesk.Api
Jwt__Audience=CoopDesk.Clients
Jwt__SigningKey=change-this-to-a-long-random-production-secret
Jwt__ExpirationMinutes=120
Cors__AllowedOrigins__0=http://localhost:4200

# Frontend Angular no Vercel
# Valor publico, pode ir no Vercel. Nao coloque token de banco aqui.
COOPDESK_API_BASE_URL=http://localhost:5298
